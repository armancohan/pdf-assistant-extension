{
  "manifest_version": 3,
  "name": "PDF Assistant",
  "version": "1.0.0",
  "description": "Summarize academic and technical PDFs (arxiv, OpenReview, conference proceedings, journals, local files) using an LLM.",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://arxiv.org/*",
    "https://www.alphaxiv.org/*",
    "https://export.arxiv.org/*",
    "https://openreview.net/*",
    "https://aclanthology.org/*",
    "https://proceedings.neurips.cc/*",
    "https://proceedings.mlr.press/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Summarize this PDF"
  }
}
